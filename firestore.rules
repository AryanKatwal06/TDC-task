rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Matchmakers can only access their own assigned clients
    match /clients/{clientId} {
      allow read:   if request.auth != null
                    && resource.data.assignedMatchmakerId == request.auth.uid;
      allow update: if request.auth != null
                    && resource.data.assignedMatchmakerId == request.auth.uid
                    && request.resource.data.assignedMatchmakerId == request.auth.uid;
      allow create: if request.auth != null;
      allow delete: if false;
    }

    // Pool profiles are read-only for all authenticated users
    match /pool/{profileId} {
      allow read:  if request.auth != null;
      allow write: if false;
    }

    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}