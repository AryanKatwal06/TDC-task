# Built files — Vite outputs here, never commit
dist/
.vite/
build/
.next/
out/
.turbo/

# Node modules — always regenerated from package.json
node_modules/

# Environment files — contain Firebase credentials and API keys
# .env.local.example IS committed — it shows which keys are needed without values
.env
.env.local
.env.development
.env.production
.env.staging
.env.test
.env.*.local

# Firebase CLI artifacts
.firebase/
firebase-debug.log
firestore-debug.log
database-debug.log
ui-debug.log
pubsub-debug.log

# Vercel deployment cache
.vercel/

# Test coverage reports
coverage/
.nyc_output/

# macOS filesystem artifacts
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes

# Windows filesystem artifacts
Thumbs.db
ehthumbs.db
desktop.ini

# Editor configs — these are personal preferences, not project config
.vscode/
!.vscode/extensions.json
.idea/
*.swp
*.swo
*.suo

# Log files
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# Misc
*.zip
*.tar.gz
.cache/
*.local